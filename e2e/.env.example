# Target URL for the running app. Leave blank to spin up `bun run dev` locally.
E2E_BASE_URL=

# Supabase — required for data seeding/teardown and programmatic admin sign-in.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Pre-seeded admin user (created via docs/seed_admin.sql).
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# Optional explicit run id; otherwise a random one is generated per run.
E2E_RUN_ID=
